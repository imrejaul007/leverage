# Production Environment Variables
# IMPORTANT: Generate secure random values for all secrets using:
# openssl rand -base64 32

# ===========================================
# DATABASE
# ===========================================
# Neon, Supabase, Railway, or any PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:5432/leverage

# ===========================================
# REDIS
# ===========================================
# Upstash, Redis Cloud, or any Redis provider
REDIS_URL=redis://host:6379

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate using: openssl rand -base64 32
JWT_SECRET=your-256-bit-secret-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Generate using: openssl rand -base64 32
OTP_SECRET=your-otp-secret-key-here

# Generate using: openssl rand -base64 32
SESSIONS_SECRET=your-sessions-secret-key-here

# Generate using: openssl rand -base64 32
# Used for encrypting sensitive data at rest (e.g., MFA secrets)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Bcrypt rounds (12 is recommended, increase for more security)
BCRYPT_ROUNDS=12

# ===========================================
# THROTTLE/RATE LIMITING
# ===========================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ===========================================
# CORS
# ===========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-domain.vercel.app,https://www.your-domain.vercel.app

# ===========================================
# TWILIO (SMS Verification)
# ===========================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===========================================
# STRIPE (Payments)
# ===========================================
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# ===========================================
# RAZORPAY (India Payments)
# ===========================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ===========================================
# OPENAI (AI Services)
# ===========================================
OPENAI_API_KEY=sk-xxxxx

# ===========================================
# PINECONE (Vector Database)
# ===========================================
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ===========================================
# MEILISEARCH (Search)
# ===========================================
MEILISEARCH_HOST=https://your-meilisearch-instance
MEILISEARCH_API_KEY=

# ===========================================
# S3/Tigris (File Storage)
# ===========================================
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=leverage-uploads
S3_REGION=us-east-1

# ===========================================
# KAFKA (Message Queue)
# ===========================================
KAFKA_BROKERS=

# ===========================================
# APPLICATION URLs
# ===========================================
FRONTEND_URL=https://your-domain.vercel.app
NEXT_PUBLIC_API_URL=https://your-api-domain.railway.app
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ===========================================
# NODE ENVIRONMENT
# ===========================================
NODE_ENV=production
